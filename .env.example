# Copy to .env and replace every placeholder before starting a local process.
# This file intentionally contains no credentials, tokens, or private keys.
GPC_SERVER_ADDR=<host:port>
GPC_SERVER_SHUTDOWN_TIMEOUT=<positive-duration>
GPC_RUNTIME_NAMESPACE=<dns-label>
GPC_OPERATION_SYNC_BUDGET=<positive-duration>
GPC_WORKER_POLL_INTERVAL=<positive-duration>
