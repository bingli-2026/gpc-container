# Typst generated artifacts
docs/**/build/
docs/**/*.pdf
*.typst-tmp

# Editor and operating-system metadata
.DS_Store
.idea/
.vscode/

# Python bytecode caches generated by Spec Kit scripts
__pycache__/
*.py[cod]

# Go build and test outputs
/bin/
*.test
*.out
*.prof
coverage/

# Node.js and Next.js generated outputs
node_modules/
frontend/node_modules/
frontend/.next/
frontend/out/
.pnpm-store/
*.tsbuildinfo

# Local configuration and credentials (templates remain versioned)
.env
.env.*
!.env.example
!*.env.example
*.pem
*.key
*.p12
*.pfx
*.kubeconfig
kubeconfig
**/secrets*.yaml
**/secrets*.yml
**/*.secret.yaml
**/*.secret.yml

# Container build outputs and local runtime state
*.tar
.docker-cache/
.docker-context/
docker-data/
