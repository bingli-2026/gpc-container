#import "../project-kit.typ": *

#show: project-document.with(
  title: "项目变更申请单",
  subtitle: "评估并审批范围、进度、预算、架构或质量基线变更",
  doc-type: "CHANGE REQUEST",
  version: "CR-001",
  date: "待填写",
  organization: "待填写",
  owner: "申请人",
  cover: false,
  toc: false,
)

#document-title(
  [项目变更申请单 CR-001],
  meta: [项目：待填写　|　申请日期：待填写　|　申请人：待填写],
)

#v(8pt)
#info-table((
  ([*变更类型*], [范围/进度/成本/技术/质量], [*优先级*], priority-badge("P1")),
  ([*期望生效日期*], [待填写], [*审批状态*], status-badge("待确认")),
  ([*关联需求/里程碑*], [待填写], [*变更编号*], [CR-001]),
))

= 变更描述

准确说明要改变什么，以及当前基线是什么。

= 变更原因与业务价值

说明问题、机会、强制性要求或未变更的后果。

= 影响分析

#data-table(
  ([维度], [影响说明], [估算变化], [责任人]),
  (
    ([范围], [增加/删除/修改哪些交付物], [待填写], [产品负责人]),
    ([进度], [影响哪些任务和关键路径], [+X 工作日], [项目经理]),
    ([成本], [硬件、人力或外部服务变化], [+¥ 待填写], [项目经理]),
    ([技术], [架构、接口、数据和迁移影响], [待填写], [技术负责人]),
    ([安全/质量], [新增风险和测试要求], [待填写], [测试/安全]),
  ),
  columns: (24mm, 1fr, 34mm, 28mm),
)

= 可选方案

#data-table(
  ([方案], [说明], [优势], [不足], [建议]),
  (
    ([A 批准], [按申请实施], [获得预期价值], [产生上述影响], status-badge("推荐")),
    ([B 延后], [放入后续版本], [保护当前里程碑], [价值延迟], status-badge("备选")),
    ([C 拒绝], [保持当前基线], [无新增成本], [问题继续存在], status-badge("不推荐")),
  ),
  columns: (22mm, 1fr, 1fr, 1fr, 23mm),
)

= 实施与回滚计划

说明实施步骤、负责人、验证方式、切换窗口和回滚条件。

= 审批

#data-table(
  ([角色], [意见], [结论], [签字/日期]),
  (
    ([项目经理], [], [□批准　□拒绝　□补充材料], []),
    ([业务负责人], [], [□批准　□拒绝　□补充材料], []),
    ([技术负责人], [], [□批准　□拒绝　□补充材料], []),
    ([项目发起人], [], [□批准　□拒绝　□补充材料], []),
  ),
  columns: (31mm, 1fr, 50mm, 37mm),
)
